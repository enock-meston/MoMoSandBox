@page "/PaymentPage"
@using MoMoSandBoxWeb.Services
@inject MoMoService MoMoService

<PageTitle>Payment Page</PageTitle>

<h3>MoMo Payment</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <label class="form-label">Phone Number:</label>
        <input @bind="phoneNumber" class="form-control" placeholder="Enter phone number" />
    </div>
    <div class="col-md-6">
        <label class="form-label">Amount:</label>
        <input @bind="amount" class="form-control" placeholder="Enter amount" />
    </div>
</div>

<button class="btn btn-primary" @onclick="ProcessPayment" disabled="@isLoading">
    @(isLoading ? "Processing..." : "Pay Now")
</button>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="mt-3">
        <div class="alert @(success ? "alert-success" : "alert-danger")" role="alert">
            @statusMessage
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(responseDetails))
{
    <div class="mt-3">
        <div class="alert alert-info" role="alert">
            <strong>Response Details:</strong>
            <pre>@responseDetails</pre>
        </div>
    </div>
}

@code {
    private string phoneNumber = "56733123453";
    private string amount = "80";
    private string statusMessage = "";
    private string responseDetails = "";
    private bool isLoading = false;
    private bool success = false;
    
    [Inject]
    protected IJSRuntime? JSRuntime { get; set; }
    
    private async Task ProcessPayment()
    {
        if (JSRuntime != null)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Payment function called!");
        }
        
        isLoading = true;
        statusMessage = "";
        responseDetails = "";

        try
        {
            var referenceId = Guid.NewGuid().ToString();

            var (ok, response) = await MoMoService.RequestToPayAsync(
                amount: amount,
                currency: "EUR",
                externalId: "00004335",
                payerPhone: phoneNumber,
                referenceId:referenceId,
                payerMessage: "MoMo Market Payment",
                payeeNote: "MoMo Market Payment",
                bearerToken: "eyJ0eXAiOiJKV1QiLCJhbGciOiJSMjU2In0.eyJjbGllbnRJZCI6IjcwZGMxZDBkLWJjNWItNGZjMy04MTBiLTlmYzk4YmI5MDg2NiIsImV4cGlyZXMiOiIyMDI2LTAzLTEzVDExOjAyOjIxLjQ4OTk3OTYyIiwic2Vzc2lvbklkIjoiMjBkYzE4MTUtNDNhNy00MmY3LWJhMDMtYjk5NjA3YmE3MThhIn0.Th2ebYej1l0vzRAW0tL0gI1tvVnnrFyQIXJ7nzkexnKSTHlRkE3tMO6MZk_ZVMkP67GzHNaMDFRwkjg_0qktcJ4T-BfcuC5NU-mZ0VmlgR51ISuqj9MGvh14NX0pDF-lKdTY3tancF1DT_6MXQAkJ3LOu_u_unn1oVHIwhfJIAb1VPS3uE0tBGwMXvd5W_oYeKMVaD1RFJhfjynJkb_N-9r4QhTNee8qqAd_P85AGINkvXcu9FzpG8iKNvm9pkrbWshfgNkYEArCx5HtLs_bi9z3clAEQEZsCcoJtxQOFapOAtz2jdsn9F8APpzCL3Fxvdta1p0fwtpUKmMXzNZWYw",
                subscriptionKey: "25407f5a9eae40528115c71fe5205961"
            );

            success = ok;
            responseDetails = response;
            
            if (ok)
            {
                statusMessage = "✅ Payment request sent successfully! (202 Accepted)";
            }
            else
            {
                statusMessage = "❌ Payment request failed!";
            }
        }
        catch (Exception ex)
        {
            success = false;
            statusMessage = $"❌ Error: {ex.Message}";
            responseDetails = ex.ToString();
        }
        finally
        {
            isLoading = false;
        }
    }
}

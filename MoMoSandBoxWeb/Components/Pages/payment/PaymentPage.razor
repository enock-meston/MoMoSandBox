@page "/payment/PaymentPage"
@inherits PaymentBase

<PageTitle>Payment Page</PageTitle>

<h3>MoMo Payment</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <label class="form-label">Phone Number:</label>
        <input @bind="phoneNumber" class="form-control" placeholder="Enter phone number" />
    </div>
    <div class="col-md-6">
        <label class="form-label">Amount:</label>
        <input @bind="amount" class="form-control" placeholder="Enter amount" />
    </div>
</div>

<button class="btn btn-primary" @onclick="ProcessPayment" disabled="@isLoading">
    @(isLoading ? "Processing..." : "Pay Now")
</button>

@if (!string.IsNullOrEmpty(statusMessage))
{
    <div class="mt-3">
        <div class="alert @(success ? "alert-success" : "alert-danger")" role="alert">
            @statusMessage
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(responseDetails))
{
    <div class="mt-3">
        <div class="alert alert-info" role="alert">
            <strong>Response Details:</strong>
            <pre>@responseDetails</pre>
        </div>
    </div>
}


